{
  "name": "@axiomantic/llmlingua-2-js",
  "version": "0.1.0",
  "description": "Typed LLMLingua-2 prompt compression for Node, via @huggingface/transformers.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "gen:version": "node scripts/gen-version.mjs",
    "build": "npm run gen:version && tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "fmt": "biome check --write .",
    "test": "vitest run",
    "test:integration": "LLMLINGUA_INTEGRATION=1 vitest run tests/integration.test.ts",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@huggingface/transformers": "^3.0.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "llmlingua",
    "llmlingua-2",
    "prompt-compression",
    "transformers",
    "huggingface",
    "onnx",
    "nlp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/axiomantic/llmlingua-2-js"
  },
  "bugs": {
    "url": "https://github.com/axiomantic/llmlingua-2-js/issues"
  },
  "homepage": "https://github.com/axiomantic/llmlingua-2-js#readme"
}
